#!/usr/bin/env bash
# Hook git pre-commit : lance les tests publics avant chaque commit.
# Installez-le avec : make install-hook

echo ""
echo "  ⚡ Flash Trading — vérification avant commit..."
echo ""

python3 -m pytest tests/levels/ -q --tb=short 2>&1

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "  ✗ Des tests publics échouent. Commit annulé."
    echo "    Corrigez les erreurs et relancez git commit."
    echo ""
    exit 1
fi

echo ""
echo "  ✓ Tous les tests publics passent."
echo ""
exit 0
